# Strapi CMS Configuration
# Use NEXT_PUBLIC_CMS_URL for client-side access; CMS_URL is used on the server
NEXT_PUBLIC_CMS_URL=http://localhost:1337
CMS_URL=http://localhost:1337
CMS_API_TOKEN=your_strapi_api_token_here

# Next.js Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Webhook / Revalidation
# Shared secret used by Strapi webhooks to trigger Next.js ISR revalidation
# Generate a strong random token: https://generate-secret.vercel.app/32
WEBHOOK_AUTH_TOKEN=your_shared_bearer_token_here

# Node Environment
NODE_ENV=development

# Formbricks — App Survey Integration
# Environment ID from: app.formbricks.com → Settings → General
NEXT_PUBLIC_FORMBRICKS_ENV_ID=your_formbricks_environment_id
# Formbricks hosted instance URL (use https://app.formbricks.com for cloud)
NEXT_PUBLIC_FORMBRICKS_APP_URL=https://app.formbricks.com
# Survey IDs — copy from each survey's Share tab after publishing
NEXT_PUBLIC_FORMBRICKS_SURVEY_BOOK_A_CALL=your_book_a_call_survey_id
NEXT_PUBLIC_FORMBRICKS_SURVEY_CUSTOM_PROJECT=your_custom_project_survey_id
